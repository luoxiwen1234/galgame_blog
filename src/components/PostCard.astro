---
import { formatDate, readingTime } from '../lib/posts';
const { post, featured = false } = Astro.props;
---

<article class:list={['post-card', { featured }]}>
  <a class="post-card-image" href={`/blog/${post.id}/`}><img src={post.data.cover} alt={post.data.coverAlt} loading="lazy" /></a>
  <div class="post-card-copy">
    <div class="post-card-meta"><a href={`/categories/${encodeURIComponent(post.data.category)}/`}>{post.data.category}</a><span>{formatDate(post.data.pubDate)} · {readingTime(post.body)} 分钟</span></div>
    <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
    <p>{post.data.description}</p>
    <a class="read-more" href={`/blog/${post.id}/`}>阅读全文 <span aria-hidden="true">→</span></a>
  </div>
</article>
